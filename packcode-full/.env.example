# =================================================================
# PackCode environment variables
# Copy this file to .env.local for local dev, and set these in
# Vercel's dashboard for production.
# DO NOT commit your real .env file — .gitignore excludes it.
# =================================================================

# Anthropic API key — get from https://console.anthropic.com
# Used by api/optimize.js to call Claude Haiku 4.5
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXX

# Dev-only Pro unlock token. Set to any random string.
# Anyone sending header "X-Pro-Token: <this value>" bypasses rate limits.
# For testing only — real Pro tier will be wired via Stripe later.
PRO_DEV_TOKEN=change-me-to-a-random-string
